# Dependencies (installed fresh inside Docker)
node_modules
wa-service/node_modules

# Build artifacts
.next
.git
.github
.vscode

# Environment files (CRITICAL: don't leak secrets into Docker context)
.env
.env.*
!.env.example

# Data & backups
backups/
scratch/
storage/
logs/
data/
contenidos-essilor/

