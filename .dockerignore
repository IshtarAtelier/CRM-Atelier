.wwebjs_auth/
.wwebjs_cache/
wa-service/.wwebjs_auth
wa-service/.wwebjs_cache

# Playwright (installed inside Docker)
.playwright-browsers/

# Agent state
.agents/

# Docker configs (not needed inside container)
docker-compose*.yml
Dockerfile

# Misc
*.md
!prisma/*.md
