# ============================================================
# bot-service / Variables de Entorno (Plantilla)
# ============================================================
# En Railway: Settings > Variables → agregar cada clave manualmente.

# API Key de Google Gemini (obligatorio)
GOOGLE_GENAI_API_KEY=tu-api-key-aqui

# URL pública del CRM en Railway (obligatorio)
# Formato: https://<nombre-del-servicio>.up.railway.app/api/bot
CRM_API_URL=https://tu-crm.up.railway.app/api/bot

# Puerto del bot 
# Railway inyecta la variable PORT automáticamente. 
# Internamente index.js ya resuelve BOT_PORT o PORT de Railway.
# NO definir PORT en Railway para evitar conflictos si corre junto a otra app.
