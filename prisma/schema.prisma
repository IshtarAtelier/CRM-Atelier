generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String
  role          String         @default("STAFF")
  // Encargado de caja: ve el saldo total de la caja en efectivo aunque no sea
  // ADMIN (los STAFF comunes ven cada movimiento pero no el acumulado).
  cashManager   Boolean        @default(false)
  // Casilla propia para avisos dirigidos (notas, pedidos, saldos). Si es null
  // se usa la casilla compartida del local (ver src/lib/vendor-email.ts).
  notificationEmail String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  cashMovements CashMovement[]
  vendorCashEntries VendorCashEntry[] @relation("VendorCashEntries")
  orders        Order[]
}

model Client {
  id            String         @id @default(cuid())
  name          String
  email         String?        @unique
  phone         String?
  dni           String?
  birthDate     DateTime?
  status        String         @default("CONTACT")
  contactSource String?
  interest      String?
  expectedValue Float?         @default(0.0)
  priority      Int            @default(0)
  isFavorite    Boolean        @default(false)
  address       String?
  insurance     String?
  doctor        String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  wantsInvoice  Boolean?
  metaLid       String?
  createdBy     String?        @default("Sistema")
  isDeleted     Boolean        @default(false)
  tasks         ClientTask[]
  interactions  Interaction[]
  orders        Order[]
  prescriptions Prescription[]
  whatsappChats WhatsAppChat[]
  tags          Tag[]          @relation("ClientToTag")

  @@index([status])
  @@index([doctor])
  @@index([isFavorite])
  @@index([name])
  @@index([phone])
  @@index([createdAt])
  @@index([dni])
  @@index([isDeleted])
}

model CashMovement {
  id         String   @id @default(cuid())
  type       String
  amount     Float
  reason     String
  userId     String
  receiptUrl String?
  createdAt  DateTime @default(now())
  category   String   @default("OTRO")
  laboratory String?
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

// Caja por vendedor: cuenta corriente individual. Saldo = CREDITO − DEBITO.
// Positivo = el vendedor tiene para cobrar; negativo = debe (adelantos,
// descuentos de post venta, etc.).
model VendorCashEntry {
  id            String   @id @default(cuid())
  vendorId      String
  type          String   // 'CREDITO' (a favor) | 'DEBITO' (descuento)
  amount        Float    // siempre positivo; el signo lo da `type`
  reason        String
  category      String   @default("OTRO") // PAGO|COMISION|ADELANTO|POST_VENTA|OTRO
  receiptUrl    String?
  // Actor: quién cargó el movimiento (denormalizado, sobrevive al borrado de usuarios)
  createdById   String?
  createdByName String?
  createdAt     DateTime @default(now())
  vendor        User     @relation("VendorCashEntries", fields: [vendorId], references: [id])

  @@index([vendorId])
  @@index([createdAt])
}

// Rendición de efectivo: un vendedor entrega a la encargada de caja los cobros
// en efectivo que recibió. Doble confirmación: el vendedor la registra (PENDING)
// y la encargada/ADMIN la confirma contando la plata (CONFIRMED). Denormalizado
// (nombres + snapshot de pagos en Json) para que el historial sobreviva a
// borrados de usuarios/pagos.
model CashHandover {
  id              String    @id @default(cuid())
  vendorId        String
  vendorName      String
  status          String    @default("PENDING") // PENDING | CONFIRMED
  expectedAmount  Float // suma de cobros en efectivo del período según el sistema
  declaredAmount  Float // lo que el vendedor declara entregar
  countedAmount   Float? // lo que la encargada cuenta al recibir
  difference      Float? // countedAmount − expectedAmount (al confirmar)
  periodFrom      DateTime
  periodTo        DateTime
  payments        Json // snapshot [{id, amount, date, client}]
  notes           String?
  confirmedById   String?
  confirmedByName String?
  confirmedAt     DateTime?
  createdAt       DateTime  @default(now())

  @@index([vendorId])
  @@index([status])
  @@index([createdAt])
}

// Arqueo de caja (cierre de lote): la encargada/ADMIN cuenta el efectivo físico
// y lo compara contra el saldo teórico del sistema. Queda el período cubierto y
// un resumen de movimientos para auditar diferencias.
model CashCount {
  id               String   @id @default(cuid())
  theoreticalTotal Float // saldo teórico de caja al momento del arqueo
  countedAmount    Float // efectivo físico contado
  difference       Float // countedAmount − theoreticalTotal
  periodFrom       DateTime // desde el arqueo anterior (o inicio del circuito)
  periodTo         DateTime
  summary          Json // {paymentsTotal, manualIn, manualOut, movementsCount} del período
  notes            String?
  closedById       String?
  closedByName     String?
  createdAt        DateTime @default(now())

  @@index([createdAt])
}

model Interaction {
  id        String   @id @default(cuid())
  clientId  String
  type      String   @default("NOTE")
  content   String
  createdAt DateTime @default(now())
  // Actor: quién ejecutó la acción (denormalizado para que el historial
  // sobreviva al borrado/renombrado de usuarios). null = registros previos.
  userId    String?
  userName  String?
  // Nota dirigida: a quién va destinada (se le avisa por email con link a la
  // ficha). Denormalizado igual que el actor.
  directedToId   String?
  directedToName String?
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model Tag {
  id                  String   @id @default(cuid())
  name                String   @unique
  color               String?  @default("#9e7f65")
  botAction           String?  @default("NONE")
  notifyPhone         String?
  autoAssignCondition String?
  clients             Client[] @relation("ClientToTag")
  orders              Order[]  @relation("OrderToTag")
}

model ClientTask {
  id          String    @id @default(cuid())
  clientId    String
  description String
  status      String    @default("PENDING")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?
  // Quién la completó/canceló y cuándo ('Sistema (cierre venta)' si fue automático)
  completedBy String?
  completedAt DateTime?
  type        String    @default("TASK")
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model Prescription {
  id               String   @id @default(cuid())
  clientId         String
  sphereOD         Float?
  cylinderOD       Float?
  axisOD           Int?
  sphereOI         Float?
  cylinderOI       Float?
  axisOI           Int?
  addition         Float?
  additionOD       Float?
  additionOI       Float?
  pd               Float?
  distanceOD       Float?
  distanceOI       Float?
  heightOD         Float?
  heightOI         Float?
  imageUrl         String?
  notes            String?
  date             DateTime @default(now())
  prescriptionType String?  @default("ADDITION")
  nearSphereOD     Float?
  nearSphereOI     Float?
  nearCylinderOD   Float?
  nearAxisOD       Int?
  nearCylinderOI   Float?
  nearAxisOI       Int?
  prismOD          String?
  prismOI          String?
  nearDistanceOD   Float?
  nearDistanceOI   Float?
  nearPd           Float?
  orders           Order[]
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model Product {
  id                    String       @id @default(cuid())
  name                  String?
  category              String
  type                  String?
  brand                 String?
  model                 String?
  stock                 Int          @default(0)
  lensIndex             String?
  unitType              String?      @default("UNIDAD")
  laboratory            String?
  price                 Float        @default(0.0)
  cost                  Float        @default(0.0)
  sphereMin             Float?
  sphereMax             Float?
  cylinderMin           Float?
  cylinderMax           Float?
  additionMin           Float?
  additionMax           Float?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  is2x1                 Boolean      @default(false)
  botRecommended        Boolean      @default(false)
  botLabel              String?
  ageGroup              String?
  bridgeWidth           Int?
  customSlug            String?
  frameHeight           Int?
  gender                String?
  imageProcessingStatus String?      @default("IDLE")
  imagenesCatalogo      String[]     @default([])
  lensWidth             Int?
  mpn                   String?
  publishToWeb          Boolean      @default(false)
  rawImageUrls          String[]     @default([])
  seoDescription        String?
  seoTags               String?
  seoTitle              String?
  templeLength          Int?
  labType               String?
  origin                String?
  diameterMax           Float?
  diameterMin           Float?
  wholesalePrice        Float        @default(0.0)
  publishToWholesale    Boolean      @default(false)
  salePrice             Float?       // Precio de oferta web ("precio tachado"). Si es > 0 y < price, se muestra y se cobra este.
  orderItems            OrderItem[]
  webProducts           WebProduct[]

  @@index([name])
  @@index([brand])
  @@index([model])
  @@index([updatedAt])
  @@index([category])
  @@index([publishToWeb])
  @@index([publishToWholesale])
}

model Order {
  id                     String         @id @default(cuid())
  clientId               String
  userId                 String
  status                 String         @default("PENDING")
  total                  Float          @default(0.0)
  paid                   Float          @default(0.0)
  isDeleted              Boolean        @default(false)
  deletedReason          String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  prescriptionId         String?
  labStatus              String?        @default("NONE")
  labSentAt              DateTime?
  labNotes               String?
  labOrderNumber         String?
  discount               Float?         @default(0.0)
  markup                 Float?         @default(0.0)
  discountCash           Float?         @default(0.0)
  discountTransfer       Float?         @default(0.0)
  discountCard           Float?         @default(0.0)
  subtotalWithMarkup     Float?         @default(0.0)
  orderType              String?        @default("QUOTE")
  frameSource            String?
  userFrameBrand         String?
  userFrameModel         String?
  userFrameNotes         String?
  labColor               String?
  labTreatment           String?
  labDiameter            String?
  labPdOd                Float?
  labPdOi                Float?
  frameA                 String?
  frameB                 String?
  frameDbl               String?
  frameEdc               String?
  labPrismOD             String?
  labPrismOI             String?
  labBaseCurve           String?
  labFrameType           String?
  labBevelPosition       String?
  smartLabScreenshot     String?
  appliedPromoDiscount   Float?
  appliedPromoName       String?
  prescriptionSnapshot   String?
  specialDiscount        Float?         @default(0)
  smartLabSector         String?
  smartLabProgress       Int?
  smartLabLastSync       DateTime?
  smartLabEntryDate      String?
  smartLabDays           Int?
  smartLabDetails        String?
  labEdgeInStore         Boolean        @default(false)
  labHeightOD            Float?
  labHeightOI            Float?
  labMaterial            String?
  labNearPdOd            Float?
  labNearPdOi            Float?
  labType                String?
  isLocked               Boolean        @default(true)
  labFrameDetails        String?
  labFrameShape          String?
  authorizedByAdmin      Boolean        @default(false)
  frameA2                String?
  frameB2                String?
  frameDbl2              String?
  frameEdc2              String?
  labFrameDetails2       String?
  labFrameShape2         String?
  postSaleCases          PostSaleCase[]
  invoices               Invoice[]
  notifications          Notification[]
  labCostEntries         LabCostEntry[]
  client                 Client         @relation(fields: [clientId], references: [id])
  prescription           Prescription?  @relation(fields: [prescriptionId], references: [id])
  user                   User           @relation(fields: [userId], references: [id])
  items                  OrderItem[]
  payments               Payment[]
  tags                   Tag[]          @relation("OrderToTag")

  @@index([clientId])
  @@index([orderType, isDeleted])
  // Cubre los anti-joins EXISTS/NOT EXISTS de Client.orders { some/none }
  // (contactos "sin atender", oportunidades de venta, saldos): filtra por cliente
  // y tipo/borrado en un solo índice, sin recorrer todas las órdenes del cliente.
  @@index([clientId, orderType, isDeleted])
  @@index([createdAt])
  @@index([userId])
  @@index([status])
  @@index([prescriptionId])
  @@index([labStatus])
  @@index([labSentAt])
}

model Invoice {
  id             String   @id @default(cuid())
  orderId        String
  cae            String
  caeExpiration  String
  voucherNumber  Int
  voucherType    Int      @default(11)
  pointOfSale    Int
  concept        Int      @default(1)
  totalAmount    Float
  docType        Int      @default(99)
  docNumber      String   @default("0")
  pdfUrl         String?
  billingAccount String   @default("ISH")
  status         String   @default("COMPLETED")
  createdAt      DateTime @default(now())
  observations   String?
  // Actor: qué usuario emitió la factura en ARCA
  createdByName  String?
  order          Order    @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([cae])
}

model OrderItem {
  id                      String   @id @default(cuid())
  orderId                 String
  productId               String?
  quantity                Int      @default(1)
  price                   Float    @default(0.0)
  eye                     String?
  sphereVal               Float?
  cylinderVal             Float?
  axisVal                 Int?
  additionVal             Float?
  pdVal                   Float?
  heightVal               Float?
  prismVal                String?
  productBrandSnapshot    String?
  productCategorySnapshot String?
  productNameSnapshot     String?
  crystalColor            String?
  crystalColorType        String?
  laboratorySnapshot      String?
  productCostSnapshot     Float?
  productTypeSnapshot      String?
  productLensIndexSnapshot String?
  productUnitTypeSnapshot  String?
  productOriginSnapshot    String?
  order                   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product                 Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id            String   @id @default(cuid())
  orderId       String
  amount        Float
  method        String
  date          DateTime @default(now())
  notes         String?
  receiptUrl    String?
  // Actor: qué usuario cargó el pago (denormalizado; 'Sistema (Payway)' en web)
  createdById   String?
  createdByName String?
  order         Order    @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([createdById])
  @@index([date])
}

model Doctor {
  id        String          @id @default(cuid())
  name      String          @unique
  createdAt DateTime        @default(now())
  payments  DoctorPayment[]
}

model WhatsAppChat {
  id             String            @id @default(cuid())
  clientId       String?
  waId           String            @unique
  profileName    String?
  lastMessageAt  DateTime?
  status         String            @default("OPEN")
  unreadCount    Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  botEnabled     Boolean           @default(true)
  archived       Boolean           @default(false)
  chatLabels     String[]          @default([])
  realPhone      String?
  chatSummary    String?
  lastFollowUpAt DateTime?
  client         Client?           @relation(fields: [clientId], references: [id])
  messages       WhatsAppMessage[]

  @@index([clientId])
  @@index([status])
  @@index([lastMessageAt])
}

model WhatsAppMessage {
  id          String       @id @default(cuid())
  chatId      String
  direction   String
  type        String       @default("TEXT")
  content     String
  mediaUrl    String?
  waMessageId String?      @unique
  status      String       @default("SENT")
  createdAt   DateTime     @default(now())
  senderName  String?
  chat        WhatsAppChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt(sort: Desc)])
}

model DoctorPayment {
  id            String   @id @default(cuid())
  doctorId      String?
  doctorName    String
  amount        Float
  method        String
  receiptUrl    String?
  notes         String?
  date          DateTime @default(now())
  // Actor: qué usuario registró el pago de comisión (salida de dinero real)
  createdById   String?
  createdByName String?
  doctor        Doctor?  @relation(fields: [doctorId], references: [id])

  @@index([doctorName])
  @@index([doctorId])
}

model Notification {
  id          String   @id @default(cuid())
  type        String
  status      String   @default("PENDING")
  message     String
  orderId     String?
  requestedBy String
  resolvedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  order       Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([orderId])
}

model MonthlyTarget {
  id        String   @id @default(cuid())
  month     Int
  year      Int
  target1   Float
  target2   Float
  target3   Float?
  // Moneda de target1-3: "USD" (se convierte a ARS con el blue del día)
  // o "ARS" (legacy, valor fijo en pesos).
  currency  String   @default("ARS")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([month, year])
}

model FixedCost {
  id        String   @id @default(cuid())
  name      String
  amount    Float
  category  String   @default("OTRO")
  month     Int
  year      Int
  notes     String?
  createdAt DateTime @default(now())
  type      String   @default("FIJO")

  @@index([month, year])
}

model ServicePricing {
  id           String   @id @default(cuid())
  name         String
  description  String?
  category     String
  subcategory  String?
  priceCash    Float
  priceCredit  Float
  creditMonths Int      @default(6)
  active       Boolean  @default(true)
  notes        String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category, active])
}

model WebProduct {
  id          String   @id @default(cuid())
  productId   String
  name        String
  slug        String   @unique
  description String?
  imageUrl    String?
  images      String[] @default([])
  imageAlts   String[] @default([]) // Texto alternativo (alt) por foto, alineado por índice con images. Vacío = alt auto-generado.
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([category])
}

model LaboratoryConfig {
  id           String   @id @default(cuid())
  name         String   @unique
  calibrado    Float    @default(0.0)
  iva          Float    @default(0.0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deliveryTime String?
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Coupon {
  id             String    @id @default(cuid())
  code           String    @unique // Guardado en MAYÚSCULAS; es lo que tipea el cliente
  discountType   String    @default("FIXED") // "FIXED" (monto $) | "PERCENT" (%)
  discountValue  Float // Monto en $ si FIXED, porcentaje si PERCENT
  isActive       Boolean   @default(true)
  expiresAt      DateTime? // null = sin vencimiento
  maxUses        Int? // null = usos ilimitados
  usedCount      Int       @default(0)
  minOrderAmount Float?    @default(0) // Compra mínima para que aplique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([code])
  @@index([isActive])
}

model CheckoutSession {
  id           String   @id @default(cuid())
  email        String?
  firstName    String?
  lastName     String?
  phone        String?
  cartData     Json
  shippingData Json?
  status       String   @default("PENDING")
  total        Float    @default(0.0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
}

model BlogPost {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  excerpt         String
  metaTitle       String?
  metaDescription String?
  content         String
  date            DateTime @default(now())
  category        String
  imageUrl        String?
  status          String   @default("DRAFT")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SocialContent {
  id          String   @id @default(cuid())
  platform    String
  format      String
  sourceType  String
  sourceId    String?
  sourceName  String?
  copy        String
  hashtags    String?
  cta         String?
  imageUrl    String?
  imagePrompt String?
  publishTips String?
  status      String   @default("DRAFT")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([platform])
  @@index([status])
  @@index([createdAt])
}

model CrystalColor {
  id        String   @id @default(cuid())
  name      String
  category  String   @default("COMPACTO")
  hexColor  String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, category])
  @@index([category, active])
}

model TeamMessage {
  id        String   @id @default(cuid())
  sender    String
  content   String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Sin FK a User a propósito: el log de auditoría debe sobrevivir al borrado
// de usuarios (con FK, un userId de un usuario eliminado haría fallar el
// insert y se perdería el registro — lo contrario de lo que busca auditar).
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  userName   String?
  action     String
  entityType String
  entityId   String
  details    Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

// Conciliación de costos de laboratorio: qué nos cobró el lab por cada número
// de pedido vs. el costo de lista cargado en el CRM. Una fila por (lab, nº pedido).
model LabCostEntry {
  id             String    @id @default(cuid())
  lab            String // OPTOVISION | GRUPO_OPTICO | otro
  labOrderNumber String
  orderId        String?
  systemCost     Float? // costo según CRM al momento del cruce (snapshot de los items)
  billedNet      Float? // subtotal de la factura (neto, sin IVA)
  billedTotal    Float? // total de la factura
  difference     Float? // costo facturado comparable - systemCost (positivo = sobrecosto)
  source         String // IMAP_PDF | CSV | SCRAPER | MANUAL
  sourceFile     String?
  invoiceDate    DateTime?
  status         String    @default("UNMATCHED") // UNMATCHED | OK | OVERCOST | UNDERCOST
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  order          Order?    @relation(fields: [orderId], references: [id])

  @@unique([lab, labOrderNumber])
  @@index([status])
  @@index([orderId])
  @@index([createdAt])
}

model PostSaleCase {
  id               String                  @id @default(cuid())
  orderId          String
  status           String                  @default("SENT")
  cost             Float                   @default(0.0)
  newOrderNumber   String?
  notes            String?
  orderOption      String?
  responsible      String?
  caseType         String?
  fault            String?
  coverage         String?
  rxData           String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  order            Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  notesList        PostSaleNote[]
  statusHistory    PostSaleStatusHistory[]

  @@index([orderId])
  @@index([status])
}

model PostSaleNote {
  id             String       @id @default(cuid())
  caseId         String
  content        String
  createdBy      String?
  createdAt      DateTime     @default(now())
  postSaleCase   PostSaleCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

model PostSaleStatusHistory {
  id             String       @id @default(cuid())
  caseId         String
  fromStatus     String
  toStatus       String
  changedBy      String?
  createdAt      DateTime     @default(now())
  postSaleCase   PostSaleCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

// Leads de ópticas para captación mayorista B2B (panel /admin/opticas,
// acceso restringido: ADMIN o emails en OPTICAS_LEADS_EMAILS).
model OpticaLead {
  id            String    @id @default(cuid())
  name          String
  phone         String?   // como se scrapeó/cargó
  phoneWa       String?   // normalizado para wa.me (549...)
  rating        Float?
  reviewsCount  Int?
  category      String?   // rubro que reporta Maps ("Óptica", "Optometrista"...)
  address       String?
  city          String?
  province      String?
  mapsUrl       String?
  placeId       String?   @unique
  website       String?
  instagram     String?
  status        String    @default("NUEVO") // NUEVO | CONTACTADO | RESPONDIO | CLIENTE | BLOCKLIST | OCULTO
  hasWhatsapp   Boolean?  // null = sin verificar
  notes         String?
  contactedAt   DateTime?
  contactedBy   String?
  source        String?   // "maps" | "csv" | "manual"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([city])
  @@index([rating])
  @@index([phoneWa])
}
