generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String
  role          String         @default("STAFF")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  cashMovements CashMovement[]
  orders        Order[]
}

model Client {
  id            String         @id @default(cuid())
  name          String
  email         String?        @unique
  phone         String?
  dni           String?
  status        String         @default("CONTACT")
  contactSource String?
  interest      String?
  expectedValue Float?         @default(0.0)
  priority      Int            @default(0)
  isFavorite    Boolean        @default(false)
  address       String?
  insurance     String?
  doctor        String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  wantsInvoice  Boolean?
  tasks         ClientTask[]
  interactions  Interaction[]
  orders        Order[]
  prescriptions Prescription[]
  whatsappChats WhatsAppChat[]
  tags          Tag[]          @relation("ClientToTag")

  @@index([status])
  @@index([doctor])
  @@index([isFavorite])
}

model CashMovement {
  id         String   @id @default(cuid())
  type       String
  amount     Float
  reason     String
  category   String   @default("OTRO")
  laboratory String?
  userId     String
  receiptUrl String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model Interaction {
  id        String   @id @default(cuid())
  clientId  String
  type      String   @default("NOTE")
  content   String
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Tag {
  id      String   @id @default(cuid())
  name    String   @unique
  color   String?  @default("#9e7f65")
  clients Client[] @relation("ClientToTag")
  orders  Order[]  @relation("OrderToTag")
}

model ClientTask {
  id          String    @id @default(cuid())
  clientId    String
  description String
  status      String    @default("PENDING")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Prescription {
  id               String   @id @default(cuid())
  clientId         String
  sphereOD         Float?
  cylinderOD       Float?
  axisOD           Int?
  sphereOI         Float?
  cylinderOI       Float?
  axisOI           Int?
  addition         Float?
  additionOD       Float?
  additionOI       Float?
  pd               Float?
  distanceOD       Float?
  distanceOI       Float?
  heightOD         Float?
  heightOI         Float?
  imageUrl         String?
  notes            String?
  date             DateTime @default(now())
  prescriptionType String?  @default("ADDITION")
  nearSphereOD     Float?
  nearSphereOI     Float?
  nearCylinderOD   Float?
  nearAxisOD       Int?
  nearCylinderOI   Float?
  nearAxisOI       Int?
  prismOD          String?
  prismOI          String?
  orders           Order[]
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Product {
  id             String      @id @default(cuid())
  name           String?
  category       String
  type           String?
  brand          String?
  model          String?
  stock          Int         @default(0)
  lensIndex      String?
  unitType       String?     @default("UNIDAD")
  laboratory     String?
  price          Float       @default(0.0)
  cost           Float       @default(0.0)
  sphereMin      Float?
  sphereMax      Float?
  cylinderMin    Float?
  cylinderMax    Float?
  additionMin    Float?
  additionMax    Float?
  is2x1          Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  botLabel       String?
  botRecommended Boolean     @default(false)
  orderItems     OrderItem[]
  webProducts    WebProduct[]
}

model Order {
  id                   String        @id @default(cuid())
  clientId             String
  userId               String
  status               String        @default("PENDING")
  total                Float         @default(0.0)
  paid                 Float         @default(0.0)
  isDeleted            Boolean       @default(false)
  deletedReason        String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  prescriptionId       String?
  labStatus            String?       @default("NONE")
  labSentAt            DateTime?
  labNotes             String?
  labOrderNumber       String?
  discount             Float?        @default(0.0)
  markup               Float?        @default(0.0)
  discountCash         Float?        @default(0.0)
  discountTransfer     Float?        @default(0.0)
  discountCard         Float?        @default(0.0)
  subtotalWithMarkup   Float?        @default(0.0)
  orderType            String?       @default("QUOTE")
  frameSource          String?
  userFrameBrand       String?
  userFrameModel       String?
  userFrameNotes       String?
  labColor             String?
  labTreatment         String?
  labDiameter          String?
  labPdOd              String?
  labPdOi              String?
  frameA               String?
  frameB               String?
  frameDbl             String?
  frameEdc             String?
  labPrismOD           String?
  labPrismOI           String?
  labBaseCurve         String?
  labFrameType         String?
  labBevelPosition     String?
  smartLabScreenshot   String?
  prescriptionSnapshot String?
  appliedPromoName     String?
  appliedPromoDiscount Float?
  specialDiscount      Float?        @default(0.0)
  invoices             Invoice[]
  client               Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  prescription         Prescription? @relation(fields: [prescriptionId], references: [id])
  user                 User          @relation(fields: [userId], references: [id])
  items                OrderItem[]
  payments             Payment[]
  tags                 Tag[]         @relation("OrderToTag")

  @@index([clientId])
  @@index([orderType, isDeleted])
  @@index([createdAt])
}

model Invoice {
  id             String   @id @default(cuid())
  orderId        String
  cae            String
  caeExpiration  String
  voucherNumber  Int
  voucherType    Int      @default(11)
  pointOfSale    Int
  concept        Int      @default(1)
  totalAmount    Float
  docType        Int      @default(99)
  docNumber      String   @default("0")
  pdfUrl         String?
  billingAccount String   @default("ISH")
  status         String   @default("COMPLETED")
  createdAt      DateTime @default(now())
  order          Order    @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([cae])
}

model OrderItem {
  id                      String   @id @default(cuid())
  orderId                 String
  productId               String?
  quantity                Int      @default(1)
  price                   Float    @default(0.0)
  eye                     String?
  sphereVal               Float?
  cylinderVal             Float?
  axisVal                 Int?
  additionVal             Float?
  pdVal                   Float?
  heightVal               Float?
  prismVal                String?
  productNameSnapshot     String?
  productBrandSnapshot    String?
  productCategorySnapshot String?
  order                   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product                 Product? @relation(fields: [productId], references: [id])
}

model Payment {
  id         String   @id @default(cuid())
  orderId    String
  amount     Float
  method     String
  date       DateTime @default(now())
  notes      String?
  receiptUrl String?
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Doctor {
  id        String          @id @default(cuid())
  name      String          @unique
  createdAt DateTime        @default(now())
  payments  DoctorPayment[]
}

model WhatsAppChat {
  id            String            @id @default(cuid())
  clientId      String?
  waId          String            @unique
  profileName   String?
  lastMessageAt DateTime?
  status        String            @default("OPEN")
  unreadCount   Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  botEnabled    Boolean           @default(true)
  archived      Boolean           @default(false)
  chatLabels    String[]          @default([])
  client        Client?           @relation(fields: [clientId], references: [id])
  messages      WhatsAppMessage[]
}

model WhatsAppMessage {
  id          String       @id @default(cuid())
  chatId      String
  direction   String
  type        String       @default("TEXT")
  content     String
  mediaUrl    String?
  waMessageId String?      @unique
  status      String       @default("SENT")
  createdAt   DateTime     @default(now())
  chat        WhatsAppChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
}

model DoctorPayment {
  id         String   @id @default(cuid())
  doctorId   String?
  doctorName String
  amount     Float
  method     String
  receiptUrl String?
  notes      String?
  date       DateTime @default(now())
  doctor     Doctor?  @relation(fields: [doctorId], references: [id])

  @@index([doctorName])
}

model Notification {
  id          String   @id @default(cuid())
  type        String
  status      String   @default("PENDING")
  message     String
  orderId     String?
  requestedBy String
  resolvedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

model MonthlyTarget {
  id        String   @id @default(cuid())
  month     Int
  year      Int
  target1   Float
  target2   Float
  target3   Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([month, year])
}

model FixedCost {
  id        String   @id @default(cuid())
  name      String
  amount    Float
  category  String   @default("OTRO")
  month     Int
  year      Int
  notes     String?
  createdAt DateTime @default(now())
  type      String   @default("FIJO")

  @@index([month, year])
}

model ServicePricing {
  id           String   @id @default(cuid())
  name         String
  description  String?
  category     String
  subcategory  String?
  priceCash    Float
  priceCredit  Float
  creditMonths Int      @default(6)
  active       Boolean  @default(true)
  notes        String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category, active])
}

model WebProduct {
  id          String   @id @default(cuid())
  productId   String   // ID del producto genérico en el CRM
  name        String
  slug        String   @unique
  description String?  // Texto comercial (puede ser generado por IA)
  imageUrl    String?  // Foto principal
  images      String[] @default([]) // Galería de fotos
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  category    String   // Ej: "Receta Mujer", "Sol Hombre"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  product     Product  @relation(fields: [productId], references: [id])
  
  @@index([productId])
  @@index([category])
}
