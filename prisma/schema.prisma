generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String
  role          String         @default("STAFF")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  cashMovements CashMovement[]
  orders        Order[]
  auditLogs     AuditLog[]
}

model Client {
  id            String         @id @default(cuid())
  name          String
  email         String?        @unique
  phone         String?
  dni           String?
  status        String         @default("CONTACT")
  contactSource String?
  interest      String?
  expectedValue Float?         @default(0.0)
  priority      Int            @default(0)
  isFavorite    Boolean        @default(false)
  address       String?
  insurance     String?
  doctor        String?
  metaLid       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  createdBy     String?        @default("Sistema")
  wantsInvoice  Boolean?
  isDeleted     Boolean        @default(false)
  tasks         ClientTask[]
  interactions  Interaction[]
  orders        Order[]
  prescriptions Prescription[]
  whatsappChats WhatsAppChat[]
  tags          Tag[]          @relation("ClientToTag")

  @@index([status])
  @@index([doctor])
  @@index([isFavorite])
  @@index([name])
  @@index([phone])
  @@index([createdAt])
  @@index([dni])
}

model CashMovement {
  id         String   @id @default(cuid())
  type       String
  amount     Float
  reason     String
  category   String   @default("OTRO")
  laboratory String?
  userId     String
  receiptUrl String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
}

model Interaction {
  id        String   @id @default(cuid())
  clientId  String
  type      String   @default("NOTE")
  content   String
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model Tag {
  id                  String   @id @default(cuid())
  name                String   @unique
  color               String?  @default("#9e7f65")
  botAction           String?  @default("NONE") // NONE, TURN_OFF, TURN_ON
  notifyPhone         String?
  autoAssignCondition String?
  clients             Client[] @relation("ClientToTag")
  orders              Order[]  @relation("OrderToTag")
}

model ClientTask {
  id          String    @id @default(cuid())
  clientId    String
  description String
  status      String    @default("PENDING")
  type        String    @default("TASK") // TASK, REVIEW_REQUEST
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model Prescription {
  id               String   @id @default(cuid())
  clientId         String
  sphereOD         Float?
  cylinderOD       Float?
  axisOD           Int?
  sphereOI         Float?
  cylinderOI       Float?
  axisOI           Int?
  addition         Float?
  additionOD       Float?
  additionOI       Float?
  pd               Float?
  distanceOD       Float?
  distanceOI       Float?
  heightOD         Float?
  heightOI         Float?
  nearPd           Float?
  nearDistanceOD   Float?
  nearDistanceOI   Float?
  imageUrl         String?
  notes            String?
  date             DateTime @default(now())
  prescriptionType String?  @default("ADDITION")
  nearSphereOD     Float?
  nearSphereOI     Float?
  nearCylinderOD   Float?
  nearAxisOD       Int?
  nearCylinderOI   Float?
  nearAxisOI       Int?
  prismOD          String?
  prismOI          String?
  orders           Order[]
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model Product {
  id                    String   @id @default(cuid())
  name                  String?
  category              String
  type                  String?
  brand                 String?
  model                 String?
  stock                 Int      @default(0)
  lensIndex             String?
  unitType              String?  @default("UNIDAD")
  laboratory            String?
  price                 Float    @default(0.0)
  wholesalePrice        Float    @default(0.0)
  cost                  Float    @default(0.0)
  sphereMin             Float?
  sphereMax             Float?
  cylinderMin           Float?
  cylinderMax           Float?
  additionMin           Float?
  additionMax           Float?
  diameterMin           Float?
  diameterMax           Float?
  is2x1                 Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  labType               String? // STOCK o LABORATORY
  botLabel              String?
  botRecommended        Boolean  @default(false)
  imageProcessingStatus String?  @default("IDLE")
  rawImageUrls          String[] @default([])
  imagenesCatalogo      String[] @default([])
  publishToWeb          Boolean  @default(false)
  // Medidas del armazón (en mm)
  lensWidth             Int?
  bridgeWidth           Int?
  templeLength          Int?
  frameHeight           Int?

  origin String? // "STOCK" or "LABORATORIO"

  // SEO & E-Commerce (TiendaNube Style)
  seoTitle       String?
  seoDescription String?
  seoTags        String?
  customSlug     String?
  mpn            String?
  gender         String?
  ageGroup       String?

  orderItems  OrderItem[]
  webProducts WebProduct[]

  @@index([name])
  @@index([brand])
  @@index([model])
  @@index([updatedAt])
  @@index([category])
}

model Order {
  id                   String         @id @default(cuid())
  clientId             String
  userId               String
  status               String         @default("PENDING")
  total                Float          @default(0.0)
  paid                 Float          @default(0.0)
  isDeleted            Boolean        @default(false)
  deletedReason        String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  prescriptionId       String?
  labStatus            String?        @default("NONE")
  labSentAt            DateTime?
  labNotes             String?
  labFrameShape        String? // Forma del armazón (redondo, cuadrado, etc)
  labFrameDetails      String? // Detalles del armazón escritos por el vendedor
  labOrderNumber       String?
  discount             Float?         @default(0.0)
  markup               Float?         @default(0.0)
  discountCash         Float?         @default(0.0)
  discountTransfer     Float?         @default(0.0)
  discountCard         Float?         @default(0.0)
  subtotalWithMarkup   Float?         @default(0.0)
  orderType            String?        @default("QUOTE")
  frameSource          String?
  userFrameBrand       String?
  userFrameModel       String?
  userFrameNotes       String?
  labType              String? // STOCK o LABORATORY
  labColor             String?
  labMaterial          String? // Material para el lab (ej: Orgánico, Poli)
  labTreatment         String?
  labDiameter          String?
  labPdOd              Float?
  labPdOi              Float?
  labNearPdOd          Float?
  labNearPdOi          Float?
  labHeightOD          Float?
  labHeightOI          Float?
  labEdgeInStore       Boolean        @default(false) // Si es TRUE, el lab solo manda los cristales tallados ("Calibra en óptica")
  frameA               String?
  frameB               String?
  frameDbl             String?
  frameEdc             String?
  labPrismOD           String?
  labPrismOI           String?
  labBaseCurve         String?
  labFrameType         String?
  labBevelPosition     String?
  smartLabScreenshot   String?
  smartLabSector       String?
  smartLabProgress     Int?
  smartLabLastSync     DateTime?
  smartLabEntryDate    String?
  smartLabDays         Int?
  smartLabDetails      String? // JSON: [{num, sector, progress, entryDate, days}]
  prescriptionSnapshot String?
  appliedPromoName     String?
  appliedPromoDiscount Float?
  specialDiscount      Float?         @default(0.0)
  isLocked             Boolean        @default(true)
  authorizedByAdmin    Boolean        @default(false)
  postSaleNotes        String?
  postSaleCost         Float?         @default(0.0)
  postSaleResponsible  String?
  postSaleOrderOption  String?
  postSaleNewOrderNumber String?
  invoices             Invoice[]
  client               Client         @relation(fields: [clientId], references: [id], onDelete: Restrict)
  prescription         Prescription?  @relation(fields: [prescriptionId], references: [id], onDelete: SetNull)
  user                 User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  items                OrderItem[]
  payments             Payment[]
  tags                 Tag[]          @relation("OrderToTag")
  notifications        Notification[]

  @@index([clientId])
  @@index([orderType, isDeleted])
  @@index([createdAt])
  @@index([userId])
  @@index([status])
  @@index([prescriptionId])
  @@index([labStatus])
}

model Invoice {
  id             String   @id @default(cuid())
  orderId        String
  cae            String
  caeExpiration  String
  voucherNumber  Int
  voucherType    Int      @default(11)
  pointOfSale    Int
  concept        Int      @default(1)
  totalAmount    Float
  docType        Int      @default(99)
  docNumber      String   @default("0")
  pdfUrl         String?
  billingAccount String   @default("ISH")
  status         String   @default("COMPLETED")
  createdAt      DateTime @default(now())
  observations   String?
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([cae])
}

model OrderItem {
  id                      String   @id @default(cuid())
  orderId                 String
  productId               String?
  quantity                Int      @default(1)
  price                   Float    @default(0.0)
  eye                     String?
  sphereVal               Float?
  cylinderVal             Float?
  axisVal                 Int?
  additionVal             Float?
  pdVal                   Float?
  heightVal               Float?
  prismVal                String?
  productNameSnapshot     String?
  productBrandSnapshot    String?
  productCategorySnapshot String?
  productCostSnapshot     Float?
  laboratorySnapshot      String?
  crystalColor            String?
  crystalColorType        String?
  order                   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product                 Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id         String   @id @default(cuid())
  orderId    String
  amount     Float
  method     String
  date       DateTime @default(now())
  notes      String?
  receiptUrl String?
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([orderId])
}

model Doctor {
  id        String          @id @default(cuid())
  name      String          @unique
  createdAt DateTime        @default(now())
  payments  DoctorPayment[]
}

model WhatsAppChat {
  id             String            @id @default(cuid())
  clientId       String?
  waId           String            @unique
  realPhone      String?
  profileName    String?
  lastMessageAt  DateTime?
  status         String            @default("OPEN")
  unreadCount    Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  botEnabled     Boolean           @default(true)
  archived       Boolean           @default(false)
  chatLabels     String[]          @default([])
  chatSummary    String?           @db.Text
  lastFollowUpAt DateTime?
  client         Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  messages       WhatsAppMessage[]

  @@index([clientId])
  @@index([status])
}

model WhatsAppMessage {
  id          String       @id @default(cuid())
  chatId      String
  direction   String
  type        String       @default("TEXT")
  content     String
  mediaUrl    String?
  waMessageId String?      @unique
  status      String       @default("SENT")
  senderName  String?
  createdAt   DateTime     @default(now())
  chat        WhatsAppChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt(sort: Desc)])
}

model DoctorPayment {
  id         String   @id @default(cuid())
  doctorId   String?
  doctorName String
  amount     Float
  method     String
  receiptUrl String?
  notes      String?
  date       DateTime @default(now())
  doctor     Doctor?  @relation(fields: [doctorId], references: [id], onDelete: SetNull)

  @@index([doctorName])
  @@index([doctorId])
}

model Notification {
  id          String   @id @default(cuid())
  type        String
  status      String   @default("PENDING")
  message     String
  orderId     String?
  requestedBy String
  resolvedBy  String?
  order       Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([orderId])
}

model MonthlyTarget {
  id        String   @id @default(cuid())
  month     Int
  year      Int
  target1   Float
  target2   Float
  target3   Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([month, year])
}

model FixedCost {
  id        String   @id @default(cuid())
  name      String
  amount    Float
  category  String   @default("OTRO")
  month     Int
  year      Int
  notes     String?
  createdAt DateTime @default(now())
  type      String   @default("FIJO")

  @@index([month, year])
}

model ServicePricing {
  id           String   @id @default(cuid())
  name         String
  description  String?
  category     String
  subcategory  String?
  priceCash    Float
  priceCredit  Float
  creditMonths Int      @default(6)
  active       Boolean  @default(true)
  notes        String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category, active])
}

model WebProduct {
  id          String   @id @default(cuid())
  productId   String // ID del producto genérico en el CRM
  name        String
  slug        String   @unique
  description String? // Texto comercial (puede ser generado por IA)
  imageUrl    String? // Foto principal
  images      String[] @default([]) // Galería de fotos
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  category    String // Ej: "Receta Mujer", "Sol Hombre"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([category])
}

model LaboratoryConfig {
  id           String   @id @default(cuid())
  name         String   @unique
  calibrado    Float    @default(0.0)
  iva          Float    @default(0.0)
  deliveryTime String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model CheckoutSession {
  id           String   @id @default(cuid())
  email        String?
  firstName    String?
  lastName     String?
  phone        String?
  cartData     Json // Store items, quantities, prices
  shippingData Json? // Store selected shipping method
  status       String   @default("PENDING") // PENDING, RECOVERED, COMPLETED, ABANDONED
  total        Float    @default(0.0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
}

model BlogPost {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  excerpt         String
  metaTitle       String?
  metaDescription String?
  content         String
  date            DateTime @default(now())
  category        String
  imageUrl        String?
  status          String   @default("DRAFT") // DRAFT, PUBLISHED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SocialContent {
  id          String   @id @default(cuid())
  platform    String // INSTAGRAM, FACEBOOK, WHATSAPP
  format      String // POST, STORY, REEL, CAROUSEL
  sourceType  String // PRODUCT, BLOG, PROMO, FREE
  sourceId    String? // ID del producto o blog post
  sourceName  String? // Nombre del producto o blog para referencia rápida
  copy        String // Texto principal generado
  hashtags    String? // Hashtags separados por espacio
  cta         String? // Call to action
  imageUrl    String? // URL de la imagen generada (S3/storage)
  imagePrompt String? // Prompt usado para generar la imagen
  publishTips String? // Indicaciones de publicación en JSON
  status      String   @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([platform])
  @@index([status])
  @@index([createdAt])
}

model CrystalColor {
  id        String   @id @default(cuid())
  name      String
  category  String   @default("COMPACTO")
  hexColor  String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, category])
  @@index([category, active])
}

model TeamMessage {
  id        String   @id @default(cuid())
  sender    String // ISHTAR, MATIAS, SYSTEM
  content   String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String? // Puede ser null si es una acción del sistema
  userName   String? // Nombre del usuario (STAFF, ADMIN, etc)
  action     String // CREATE, UPDATE, DELETE
  entityType String // ORDER, CONTACT, PAYMENT, etc.
  entityId   String
  details    Json? // Qué campos cambiaron o razón
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}
