{
  "name": "optical-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npx prisma generate && npx prisma migrate deploy && next build",
    "postinstall": "npx prisma generate",
    "start": "next start -p $PORT",
    "lint": "eslint",
    "whatsapp": "node whatsapp-server.js",
    "db:backup": "node scripts/backup-db.js",
    "db:migrate": "node scripts/backup-db.js && npx prisma migrate dev",
    "db:deploy": "node scripts/backup-db.js && npx prisma migrate deploy",
    "db:reset": "npx prisma migrate reset",
    "db:seed": "npx prisma db seed",
    "db:studio": "npx prisma studio",
    "db:status": "npx prisma migrate status"
  },
  "dependencies": {
    "@afipsdk/afip.js": "^1.2.3",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "framer-motion": "^12.34.3",
    "jose": "^6.1.3",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "openai": "^6.27.0",
    "qrcode-terminal": "^0.12.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0",
    "tesseract.js": "^7.0.0",
    "whatsapp-web.js": "^1.34.6",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
