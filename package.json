{
  "name": "optical-crm",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "npx prisma generate && next build",
    "start": "npx prisma migrate deploy && next start -p ${PORT:-3000} -H 0.0.0.0",
    "lint": "eslint",
    "verify": "node scripts/verify-build.js",
    "whatsapp": "node scripts/whatsapp-server.js",
    "db:backup": "node scripts/backup-db.js",
    "db:migrate": "node scripts/backup-db.js && npx prisma migrate dev",
    "db:deploy": "node scripts/backup-db.js && npx prisma migrate deploy",
    "db:reset": "npx prisma migrate reset",
    "db:seed": "npx prisma db seed",
    "db:studio": "npx prisma studio",
    "db:status": "npx prisma migrate status"
  },
  "dependencies": {
    "@afipsdk/afip.js": "^1.2.3",
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "@langchain/core": "^1.1.40",
    "@langchain/google-genai": "^2.1.27",
    "@langchain/langgraph": "^1.2.9",
    "@prisma/client": "^5.22.0",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "axios": "^1.15.1",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase-admin": "^13.8.0",
    "framer-motion": "^12.34.3",
    "jose": "^6.1.3",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.575.0",
    "next": "15.1.11",
    "nodemailer": "^8.0.4",
    "openai": "^6.27.0",
    "playwright": "^1.59.1",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "^3.5.0",
    "tesseract.js": "^7.0.0",
    "whatsapp-web.js": "^1.34.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "better-sqlite3": "^12.8.0",
    "eslint": "^9",
    "eslint-config-next": "15.1.11",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
