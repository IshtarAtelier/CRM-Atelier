{
  "name": "optical-crm",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.17.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "npx prisma generate && next build && (PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers npx playwright install chromium || echo 'Playwright install skipped')",
    "postinstall": "npx playwright install chromium",
    "start": "npx prisma migrate deploy && next start -p ${PORT:-3000} -H 0.0.0.0",
    "lint": "eslint",
    "verify": "node scripts/checks/verify-build.js",
    "db:backup": "node scripts/maintenance/backup-db.js",
    "db:migrate": "node scripts/maintenance/backup-db.js && npx prisma migrate dev",
    "db:deploy": "node scripts/maintenance/backup-db.js && npx prisma migrate deploy",
    "db:reset": "npx prisma migrate reset",
    "db:seed": "npx prisma db seed",
    "db:studio": "npx prisma studio",
    "db:status": "npx prisma migrate status",
    "analyze": "ANALYZE=true next build"
  },
  "dependencies": {
    "@afipsdk/afip.js": "^1.2.3",
    "@google/genai": "^2.2.0",
    "@langchain/core": "^1.1.48",
    "@langchain/google-genai": "^2.1.31",
    "@langchain/google-vertexai-web": "^2.1.31",
    "@prisma/client": "^5.22.0",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "emoji-picker-react": "^4.19.1",
    "firebase-admin": "^14.0.0",
    "framer-motion": "^12.34.3",
    "jose": "^6.1.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.575.0",
    "marked": "^18.0.5",
    "next": "^15.5.19",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.4",
    "playwright": "^1.60.0",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "rss-parser": "^3.13.0",
    "sanitize-html": "^2.17.5",
    "sharp": "^0.35.2",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "zod": "^4.3.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "eslint": "^9",
    "eslint-config-next": "15.1.11",
    "eslint-plugin-unused-imports": "^4.4.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
