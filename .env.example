# ===========================================
# Atelier Óptica CRM — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to git!

# ===== Database =====
DATABASE_URL=postgresql://postgres:localpassword@localhost:5432/atelier
PROD_DATABASE_URL=  # Production DB URL (for scripts only)

# ===== Authentication =====
JWT_SECRET=  # REQUIRED: Generate with: openssl rand -hex 32
BOT_API_KEY=  # REQUIRED: API key for wa-service ↔ CRM communication

# ===== Cron Jobs =====
CRON_SECRET=  # REQUIRED: Secret for authenticating cron job requests

# ===== Email (Gmail SMTP) =====
EMAIL_USER=  # Gmail address for sending emails
EMAIL_PASS=  # Gmail App Password (not your regular password)
ADMIN_EMAIL=  # Admin email for notifications

# ===== Google Cloud / AI =====
GOOGLE_GENAI_API_KEY=  # Google Gemini API key
GOOGLE_CLOUD_PROJECT=  # GCP Project ID
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_VERTEX_AI_WEB_CREDENTIALS=  # Service Account JSON (or use GOOGLE_APPLICATION_CREDENTIALS)

# ===== Google Places (Reviews) =====
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=  # Google Place ID for the store (used in reviews page)

# ===== Payment Gateway (PayWay) =====
PAYWAY_SITE_ID=
PAYWAY_PUBLIC_KEY=
PAYWAY_PRIVATE_KEY=
PAYWAY_ENVIRONMENT=  # 'sandbox' or 'production'

# ===== Meta / WhatsApp =====
META_ACCESS_TOKEN=  # Meta Business API token
META_PIXEL_ID=  # Meta Pixel ID for server-side tracking
NEXT_PUBLIC_META_PIXEL_ID=  # Meta Pixel ID for client-side tracking

# ===== Meta Marketing API (scripts/ads — ver scripts/ads/CLAUDE.md) =====
META_ADS_TOKEN=  # token de LECTURA (ads_read), usuario de sistema del BM
META_ADS_WRITE_TOKEN=  # token con ads_management; solo escrituras confirmadas
META_APP_ID=  # id de la app de developers.facebook.com (junto con el secret, arma el app token para debug_token)
META_APP_SECRET=  # app secret para appsecret_proof y app token (recomendado)
META_AD_ACCOUNT_ID=  # cuenta publicitaria, formato act_XXXXXXXXX
# META_ALLOW_WRITES=1  # pasar INLINE en el comando (no exportar) solo para una operación de escritura confirmada

# ===== Google Ads API (scripts/ads/lib/google_client.js — pendiente developer token) =====
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
# GOOGLE_ADS_ALLOW_WRITES=1  # mismo criterio que META_ALLOW_WRITES: inline, nunca export

# ===== WhatsApp Service =====
WA_SERVER_URL=http://localhost:3001  # wa-service URL
WA_API_KEY=  # API key to protect wa-service endpoints
NEXT_PUBLIC_WA_URL=  # Public WhatsApp widget URL

# ===== CORS =====
CORS_ORIGINS=http://localhost:3000  # Comma-separated allowed origins

# ===== Optional =====
FIREBASE_PROJECT_ID=  # For cloud file storage
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_PHONE=  # WhatsApp phone for storefront

# ===== Medición / Analítica =====
# GA4: si se setea, TrackingScripts carga Google Analytics (solo con consentimiento).
# La analítica PROPIA del sitio (tabla AnalyticsEvent + /admin/analitica) NO depende de esto.
NEXT_PUBLIC_GA_ID=  # ej: G-XXXXXXXXXX
NEXT_PUBLIC_APP_URL=https://atelieroptica.com.ar  # usado por el feed de Shopping y el CAPI web

# ===== Email (Resend) =====
# IMPORTANTE: sin EMAIL_FROM, los correos salen desde onboarding@resend.dev (dominio no propio).
EMAIL_FROM=Atelier Óptica <ventas@atelieroptica.com.ar>

# ===== Base de datos / escalabilidad =====
# En Railway con varias instancias (Next + wa-service + crons) conviene limitar el pool
# de Prisma por servicio para no agotar max_connections. Agregar a DATABASE_URL, ej:
#   ...&connection_limit=5&pool_timeout=20
# o usar un pooler (pgbouncer) con pgbouncer=true.
