# Environment Variables Template
# Copy this file to .env and fill in the values

# PostgreSQL Database (Railway provides this automatically)
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"
DIRECT_URL="postgresql://user:password@host:5432/dbname?schema=public"

# For local development with SQLite, use:
# DATABASE_URL="file:./dev.db"

JWT_SECRET="change-this-to-a-secure-random-string"

# ARCA / AFIP - Facturación Electrónica (Multi-cuenta)
# Cuenta ISHTAR
AFIP_CUIT_ISH=20409378472
AFIP_ACCESS_TOKEN_ISH=
AFIP_CERT_ISH=
AFIP_KEY_ISH=

# Cuenta YANI
AFIP_CUIT_YANI=
AFIP_ACCESS_TOKEN_YANI=
AFIP_CERT_YANI=
AFIP_KEY_YANI=

# Cuenta LUCIA
AFIP_CUIT_LUCIA=
AFIP_ACCESS_TOKEN_LUCIA=
AFIP_CERT_LUCIA=
AFIP_KEY_LUCIA=

# Railway sets PORT automatically
PORT=3000
